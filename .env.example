# DATABASE CONFIGURATION
DATABASE_URL=postgresql://user:password@localhost:5432/aloha_db

# APPLICATION CONFIGURATION
APP_URL=http://localhost:5010

# AUTH.JS CONFIGURATION
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=generate_secret_with_openssl

# GOOGLE OAUTH (Auth Channel)
AUTH_GOOGLE_ID=your_google_id
AUTH_GOOGLE_SECRET=your_google_secret

# GITHUB OAUTH (Auth Channel)
AUTH_GITHUB_ID=your_github_id
AUTH_GITHUB_SECRET=your_github_secret

# X (TWITTER) OAUTH (Deployment)
AUTH_TWITTER_ID=your_twitter_id
AUTH_TWITTER_SECRET=your_twitter_secret

# LINKEDIN OAUTH (Deployment)
AUTH_LINKEDIN_ID=your_linkedin_id
AUTH_LINKEDIN_SECRET=your_linkedin_secret

# FACEBOOK OAUTH (Deployment)
AUTH_FACEBOOK_ID=your_facebook_app_id
AUTH_FACEBOOK_SECRET=your_facebook_app_secret

# INSTAGRAM OAUTH (Deployment)
AUTH_INSTAGRAM_ID=your_instagram_app_id
AUTH_INSTAGRAM_SECRET=your_instagram_app_secret

# THREADS OAUTH (Deployment)
AUTH_THREADS_ID=your_threads_app_id
AUTH_THREADS_SECRET=your_threads_app_secret

# TIKTOK OAUTH (Deployment)
AUTH_TIKTOK_ID=your_tiktok_id
AUTH_TIKTOK_SECRET=your_tiktok_secret

# REDDIT OAUTH (Deployment)
AUTH_REDDIT_ID=your_reddit_client_id
AUTH_REDDIT_SECRET=your_reddit_client_secret

# PINTEREST OAUTH (Deployment)
# Create an app at https://developers.pinterest.com/apps/ (requires business account)
# Redirect URI: {APP_URL}/api/auth/callback/pinterest
AUTH_PINTEREST_ID=your_pinterest_app_id
AUTH_PINTEREST_SECRET=your_pinterest_app_secret

# YOUTUBE OAUTH (Deployment)
# Separate Google Cloud OAuth 2.0 Client ID from the AUTH_GOOGLE_* login client.
# Enable the YouTube Data API v3 on the project. Redirect URI:
# {APP_URL}/api/auth/callback/youtube
AUTH_YOUTUBE_ID=your_youtube_client_id
AUTH_YOUTUBE_SECRET=your_youtube_client_secret

# EMAIL (RESEND)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM="Aloha <hey@usealoha.app>"

# AI CONFIGURATION
# OpenRouter is the single upstream LLM gateway — all Aloha AI calls route through it.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# NOTION (Muse brand-corpus ingest)
# Create an integration at https://www.notion.so/my-integrations with OAuth enabled.
# Redirect URI: {APP_URL}/api/notion/callback
NOTION_OAUTH_CLIENT_ID=your_notion_client_id
NOTION_OAUTH_CLIENT_SECRET=your_notion_client_secret

# UPSTASH QSTASH CONFIGURATION
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your_qstash_token_here
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key_here
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key_here

# EARLY-ACCESS ALLOWLISTS (comma-separated emails)
# BROADCASTS_ALLOWLIST=you@example.com,teammate@example.com
# MUSE_ALLOWLIST=you@example.com,teammate@example.com

# TELEGRAM MTPROTO API (from my.telegram.org/apps)
# Create one app and use these credentials for all users
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# OBSERVABILITY (all optional — app boots without them)
# Sentry: error + perf tracking. Get DSN from sentry.io project settings.
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Required only for source-map upload at build time:
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_xxx
# Axiom: log aggregation via next-axiom SDK (no Vercel log drain needed —
# bypasses Vercel's 4KB per-invocation log truncation). Create dataset +
# ingest token at axiom.co. Tokens are NEXT_PUBLIC_* because next-axiom
# uses the same one for client-side web vitals; scope it to ingest-only.
# NEXT_PUBLIC_AXIOM_DATASET=aloha
# NEXT_PUBLIC_AXIOM_TOKEN=xaat-xxx
# NEXT_PUBLIC_AXIOM_LOG_LEVEL=info
