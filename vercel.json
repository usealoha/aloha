{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"crons": [
		{
			"path": "/api/cron/cleanup-deleted-posts?key=${CRON_SECRET}",
			"schedule": "0 0 * * *"
		},
		{
			"path": "/api/cron/automations?key=${CRON_SECRET}",
			"schedule": "* * * * *"
		}
	],
	"git": {
		"deploymentEnabled": false
	}
}
